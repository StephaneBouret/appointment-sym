{% extends "base.html.twig" %}

{% block title %}
	{{ seoTitle }}
	- Séances avec France Tuncq
{% endblock %}
{% block meta_description %}
	{{ seoMeta }}
{% endblock %}

{% block body %}
	<div class="container py-4">
		<h1>{{ seoTitle }}</h1>

		<p>
			France Tuncq propose un accompagnement individuel pour les personnes situées à
			{{ city }}
			et dans les environs.
												Ces séances s'adressent à celles et ceux qui ressentent le besoin de faire le point, de traverser une étape de vie avec plus de clarté ou de mieux comprendre leurs ressources personnelles.
		</p>

		{% if cityNote is defined %}
			<p>{{ cityNote }}</p>
		{% endif %}

		<h2>Un accompagnement pour mieux se comprendre</h2>
		<p>
			Cet accompagnement peut soutenir les périodes de transition personnelle ou professionnelle, les questionnements de fond, les phases de doute ou le besoin de retrouver un axe plus juste.
		</p>

		<p>
			L'approche proposée par France Tuncq repose sur l'écoute, l'expérience, la qualité de présence et, lorsque cela est pertinent, sur des outils de connaissance de soi complémentaires.
		</p>

		<h2>Prendre rendez-vous</h2>
		<p>
			Choisissez votre type de séance et réservez directement en ligne.
		</p>

		<a href="{{ path('app_appointment_types') }}" class="btn btn-primary">
			Voir les rendez-vous
		</a>

		<p class="mt-3">
			En savoir plus :
			<a href="{{ path('app_accompagnement_individuel') }}">découvrir l'accompagnement individuel</a>.
		</p>

		{% if relatedPages is defined and relatedPages is not empty %}
			<section class="mt-4">
				<h2>Autres secteurs</h2>
				<ul>
					{% for related in relatedPages %}
						<li>
							<a href="{{ path('seo_local_page', { slug: related.slug }) }}">
								Accompagnement individuel à
								{{ related.city }}
							</a>
						</li>
					{% endfor %}
				</ul>
			</section>
		{% endif %}

		<section class="mt-4">
			<h2>Questions fréquentes</h2>

			<div class="mb-3">
				<h3>Peut-on réserver une séance depuis {{ city }} ?</h3>
				<p>
					Oui, les personnes situées à {{ city }} et dans les environs peuvent réserver une séance avec France Tuncq.
				</p>
			</div>

			<div class="mb-3">
				<h3>À qui s'adresse cet accompagnement ?</h3>
				<p>
					Il s'adresse à toute personne souhaitant mieux comprendre ce qu'elle traverse, clarifier sa situation et avancer avec plus de cohérence dans sa vie personnelle ou professionnelle.
				</p>
			</div>
		</section>
	</div>
{% endblock %}

{% block structured_data %}
	{{ parent() }}

	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "WebPage",
			"name": "{{ seoTitle|e('js') }}",
			"url": "{{ absolute_url(path('seo_local_page', {slug: slug})) }}",
			"inLanguage": "fr-FR"
		}
	</script>

	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "Service",
			"name": "Accompagnement individuel",
			"provider": {
				"@type": "LocalBusiness",
				"name": "France Tuncq"
			},
			"areaServed": {
				"@type": "City",
				"name": "{{ city|e('js') }}"
			},
			"serviceType": "Accompagnement individuel et transition de vie"
		}
	</script>

	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "BreadcrumbList",
			"itemListElement": [
				{
					"@type": "ListItem",
					"position": 1,
					"name": "Accueil",
					"item": "{{ absolute_url(path('app_home')) }}"
				},
				{
					"@type": "ListItem",
					"position": 2,
					"name": "Accompagnement individuel",
					"item": "{{ absolute_url(path('app_accompagnement_individuel')) }}"
				},
				{
					"@type": "ListItem",
					"position": 3,
					"name": "{{ city|e('js') }}",
					"item": "{{ absolute_url(path('seo_local_page', {slug: slug})) }}"
				}
			]
		}
	</script>

	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": [
				{
					"@type": "Question",
					"name": "Peut-on réserver une séance depuis {{ city|trim|e('js') }} ?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Oui, les personnes situées à {{ city|trim|e('js') }} et dans les environs peuvent réserver une séance avec France Tuncq."
					}
				},
				{
					"@type": "Question",
					"name": "À qui s'adresse cet accompagnement ?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Cet accompagnement s'adresse à toute personne souhaitant mieux comprendre ce qu'elle traverse, clarifier sa situation et avancer avec plus de cohérence dans sa vie personnelle ou professionnelle."
					}
				}
			]
		}
	</script>
{% endblock %}
